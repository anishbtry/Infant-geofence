<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/purple_primary">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Fixed hero: stays in place; bottom sheet slides over the lower area -->
        <LinearLayout
            android:id="@+id/hero_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="48dp"
            android:paddingBottom="40dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">
                        <View
                            android:layout_width="7dp"
                            android:layout_height="7dp"
                            android:background="@drawable/circle_yellow_dot" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <FrameLayout
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:background="@drawable/circle_pulse_outer"
                    android:layout_gravity="center" />

                <View
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:background="@drawable/circle_pulse_inner"
                    android:layout_gravity="center" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="45dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    app:strokeWidth="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_default_avatar"
                        android:scaleType="fitCenter" />
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_child_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading…"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#33FFFFFF"
                app:strokeColor="#66FFFFFF"
                app:strokeWidth="1dp">
                <TextView
                    android:id="@+id/tv_online_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Offline"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Slides up over the hero; expand to full screen -->
        <FrameLayout
            android:id="@+id/dashboard_bottom_sheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="12dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
            app:behavior_draggable="true"
            app:behavior_fitToContents="false"
            app:behavior_hideable="false"
            app:behavior_peekHeight="360dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@drawable/bg_bottom_sheet">

                <com.google.android.material.bottomsheet.BottomSheetDragHandleView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="10dp"
                    android:paddingBottom="6dp" />

                <androidx.core.widget.NestedScrollView
                    android:id="@+id/sheet_nested_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:scrollbars="none"
                    android:fillViewport="true"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="32dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_fence_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F5F5F7"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp"
                            android:gravity="center_vertical">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                app:cardCornerRadius="22dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#E8F7F8"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:id="@+id/iv_fence_icon"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_fence"
                                    android:tint="@color/purple_primary"
                                    android:padding="10dp"
                                    android:scaleType="fitCenter" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="14dp">

                                <TextView
                                    android:id="@+id/tv_fence_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="No Geofence Set"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A1A1A" />

                                <TextView
                                    android:id="@+id/tv_fence_subtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Go to Geofence tab to draw a safe zone"
                                    android:textSize="12sp"
                                    android:textColor="#999999"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_alert"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ALERT"
                                android:textColor="@color/white"
                                android:visibility="gone"
                                app:chipBackgroundColor="#FF3B30"
                                app:chipMinHeight="28dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Device Info"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F5F5F7"
                            app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:padding="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="📡 Satellites" android:textSize="11sp" android:textColor="#999999" />
                                <TextView
                                    android:id="@+id/tv_satellites"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="--" android:textSize="16sp" android:textStyle="bold"
                                    android:textColor="#1A1A1A" android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F5F5F7"
                            app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:padding="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="💨 Speed" android:textSize="11sp" android:textColor="#999999" />
                                <TextView
                                    android:id="@+id/tv_speed"
                                    android:layout_width="match_parent" android:layout_height="wrap_content"
                                    android:text="--" android:textSize="16sp" android:textStyle="bold"
                                    android:textColor="#1A1A1A" android:layout_marginTop="4dp"
                                    android:maxLines="1"
                                    android:ellipsize="end" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#FFF0F0"
                            app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:padding="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Status" android:textSize="11sp" android:textColor="#FF3B30" />
                                <TextView
                                    android:id="@+id/tv_fence_status_chip"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Unknown" android:textSize="14sp" android:textStyle="bold"
                                    android:textColor="#FF3B30" android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F5F5F7"
                            app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:padding="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="📍 Latitude" android:textSize="11sp" android:textColor="#999999" />
                                <TextView
                                    android:id="@+id/tv_latitude"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="--" android:textSize="14sp" android:textStyle="bold"
                                    android:textColor="#1A1A1A" android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#F5F5F7"
                            app:strokeWidth="0dp">
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="vertical" android:padding="12dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="📍 Longitude" android:textSize="11sp" android:textColor="#999999" />
                                <TextView
                                    android:id="@+id/tv_longitude"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="--" android:textSize="14sp" android:textStyle="bold"
                                    android:textColor="#1A1A1A" android:layout_marginTop="4dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#F5F5F7"
                        app:strokeWidth="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp"
                            android:gravity="center_vertical">

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                app:cardCornerRadius="20dp"
                                app:cardElevation="0dp"
                                app:cardBackgroundColor="#E8F7F8"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_timeline"
                                    android:tint="@color/purple_primary"
                                    android:padding="8dp"
                                    android:scaleType="fitCenter" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Last Update"
                                    android:textSize="11sp"
                                    android:textColor="#999999" />

                                <TextView
                                    android:id="@+id/tv_last_update"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="No data yet"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#1A1A1A"
                                    android:layout_marginTop="2dp" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_fence"
                                android:tint="#CCCCCC" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>
            </LinearLayout>
        </FrameLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
